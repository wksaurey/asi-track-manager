# ASI Track Manager — Production Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

SECRET_KEY=generate-a-new-key-with-python-c-import-secrets-print-secrets-token_urlsafe-50
DEBUG=False
ALLOWED_HOSTS=schedule.asi.com,localhost
CSRF_TRUSTED_ORIGINS=https://schedule.asi.com,https://localhost
DB_PATH=/app/db/db.sqlite3

# Only needed if using GitHub webhook auto-update (Option A)
# WEBHOOK_SECRET=choose-a-long-random-string-here
